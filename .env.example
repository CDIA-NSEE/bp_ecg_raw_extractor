# MINIO / S3-compatible object storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Bucket names (defaults already set in config.py)
BUCKET_IMAGES=bp-ecg-dev-images
BUCKET_INTAKE=bp-ecg-dev-intake
BUCKET_LAKE=bp-ecg-dev-lake

# Iceberg catalog via Nessie REST
NESSIE_URI=http://localhost:19120/iceberg
ICEBERG_TABLE_NAME=bp_ecg.ecg_records_raw

# Processing concurrency
OCR_WORKERS=2
ASYNC_CONCURRENCY=10

# PaddleOCR
PADDLE_USE_GPU=false
PADDLE_LANG=pt

# Image crop region (relative coordinates 0.0–1.0)
# CROP_REGION='{"x_min": 0.1, "y_min": 0.1, "x_max": 0.9, "y_max": 0.9}'
# OCR_REGION='{"x_min": 0.0, "y_min": 0.0, "x_max": 1.0, "y_max": 0.15}'

# Prometheus metrics server
METRICS_PORT=8000

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=dev
